{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noImplicitOverride": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": {
          "globalErrorInEffectCatch": "off"
        }
      }
    ]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
