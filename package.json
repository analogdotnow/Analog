{
  "name": "analog",
  "private": true,
  "scripts": {
    "build": "dotenv -- turbo run build",
    "dev": "dotenv -- turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,css,md}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "db:generate": "turbo run db:generate",
    "db:migrate": "dotenv -- turbo run db:migrate",
    "db:push": "dotenv -- turbo run db:push",
    "db:studio": "dotenv -- turbo run db:studio"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6"
  },
  "packageManager": "bun@1.3.0",
  "catalog": {
    "@ai-sdk/cerebras": "^2.0.45",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/react": "^3.0.161",
    "@composio/core": "^0.6.10",
    "@formkit/tempo": "^1.0.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/microsoft-graph-types": "^2.40.0",
    "@trpc/server": "^11.16.0",
    "@types/node": "^24.12.2",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.159",
    "better-auth": "^1.6.3",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.39.4",
    "next": "16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rivetkit": "2.2.1",
    "remeda": "^2.33.7",
    "superjson": "^2.2.6",
    "superjson-temporal": "^0.4.0",
    "temporal-polyfill": "^0.3.2",
    "temporal-zod": "https://pkg.pr.new/analogdotnow/temporal-utils/temporal-zod@395939e",
    "trpc-to-mcp": "^1.3.2",
    "trpc-to-openapi": "^3.2.0",
    "typescript": "^6",
    "zod": "^4.3.6"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ]
}
